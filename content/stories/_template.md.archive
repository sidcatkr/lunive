---
# ──────────────────────────────────────────────────────────────────
# REQUIRED
# ──────────────────────────────────────────────────────────────────
title: ""
date: ""                  # ISO, e.g. "2026-04-15"

# ──────────────────────────────────────────────────────────────────
# OPTIONAL metadata
# ──────────────────────────────────────────────────────────────────
description: ""           # Short blurb shown on the index and in <meta>
tags: []                  # e.g. ["legato", "discord", "product"]
subtitle: ""              # One-line below the title on the hero card

# ──────────────────────────────────────────────────────────────────
# FEATURED STORY  (choose ONE story per list to lead the /stories page)
# ──────────────────────────────────────────────────────────────────
# featured: true         # promotes this story to the big hero card on /stories
# expand: true           # default. Set to false for a static hero card (no scroll takeover)

# ──────────────────────────────────────────────────────────────────
# HERO MEDIA  (the visual on the right side of the dark hero card)
# ──────────────────────────────────────────────────────────────────
# Three `type` options — pick one:
#
#   1. image   — still image (URL or /public path)
#   2. video   — looping muted autoplay video (mp4/webm)
#   3. component — a React component registered in
#                  src/components/stories/hero-components.tsx
#
# heroMedia:
#   type: image
#   src: https://images.unsplash.com/photo-...?w=1600&q=80
#   alt: "Description of the image"
#
# heroMedia:
#   type: video
#   src: /stories/demo.mp4
#   poster: /stories/demo.jpg   # optional fallback frame
#   alt: "Demo video of the product"
#
# heroMedia:
#   type: component
#   component: legato-visual    # key must exist in HERO_COMPONENTS
#   alt: "Interactive Legato visualization"
---

